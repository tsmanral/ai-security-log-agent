# ============================================================================
# LSADRA V3 — Environment Variables
# Copy this file to .env and customize for your deployment.
# ============================================================================

# ── Networking ───────────────────────────────────────────────────────────
API_PORT=8000
DASH_PORT=8501

# ── Security ─────────────────────────────────────────────────────────────
# IMPORTANT: Generate a unique secret for production!
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SENTINEL_JWT_SECRET=changeme-in-production
SENTINEL_REQUIRE_TLS=false

# ── TLS Certificates (when REQUIRE_TLS=true) ─────────────────────────────
# SENTINEL_TLS_CERT=/path/to/cert.pem
# SENTINEL_TLS_KEY=/path/to/key.pem

# ── Detection ────────────────────────────────────────────────────────────
SENTINEL_MIN_BASELINE_EVENTS=200
SENTINEL_PSI_DRIFT_THRESHOLD=0.2
SENTINEL_FP_RATE_THRESHOLD=0.15

# ── Severity Thresholds ──────────────────────────────────────────────────
SENTINEL_SEVERITY_CRITICAL=0.9
SENTINEL_SEVERITY_HIGH=0.7
SENTINEL_SEVERITY_MEDIUM=0.4

# ── Incident Management ─────────────────────────────────────────────────
SENTINEL_INCIDENT_WINDOW_MINUTES=15

# ── Device Monitoring ────────────────────────────────────────────────────
SENTINEL_DEVICE_ONLINE_THRESHOLD_MINUTES=5

# ── Threat Intelligence ──────────────────────────────────────────────────
# Get a free API key at https://www.abuseipdb.com/account/api
SENTINEL_ABUSEIPDB_API_KEY=

# ── Data Retention ───────────────────────────────────────────────────────
SENTINEL_RETENTION_DAYS=30

# ── Metrics ──────────────────────────────────────────────────────────────
SENTINEL_METRICS_INTERVAL_MINUTES=5
