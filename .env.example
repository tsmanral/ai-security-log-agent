# ============================================================================
# LSADRA V3 — Environment Variables
# Copy this file to .env and customize for your deployment.
# ============================================================================

# ── Networking ───────────────────────────────────────────────────────────
API_PORT=8000
DASH_PORT=8501

# ── Security ─────────────────────────────────────────────────────────────
# IMPORTANT: Generate a unique secret for production!
# python -c "import secrets; print(secrets.token_urlsafe(32))"
LSADRA_JWT_SECRET=changeme-in-production
LSADRA_REQUIRE_TLS=false
# Reverse-proxy IPs whose X-Forwarded-Proto may be trusted for TLS checks
# (comma-separated). Leave empty unless the API runs behind a known proxy.
LSADRA_TRUSTED_PROXY_IPS=

# ── TLS Certificates (when REQUIRE_TLS=true) ─────────────────────────────
# LSADRA_TLS_CERT=/path/to/cert.pem
# LSADRA_TLS_KEY=/path/to/key.pem

# ── Detection ────────────────────────────────────────────────────────────
LSADRA_MIN_BASELINE_EVENTS=200
LSADRA_PSI_DRIFT_THRESHOLD=0.2
LSADRA_FP_RATE_THRESHOLD=0.15

# ── Severity Thresholds ──────────────────────────────────────────────────
LSADRA_SEVERITY_CRITICAL=0.9
LSADRA_SEVERITY_HIGH=0.7
LSADRA_SEVERITY_MEDIUM=0.4

# ── Incident Management ─────────────────────────────────────────────────
LSADRA_INCIDENT_WINDOW_MINUTES=15

# ── Device Monitoring ────────────────────────────────────────────────────
LSADRA_DEVICE_ONLINE_THRESHOLD_MINUTES=5

# ── Threat Intelligence ──────────────────────────────────────────────────
# Get a free API key at https://www.abuseipdb.com/account/api
LSADRA_ABUSEIPDB_API_KEY=

# ── Data Retention ───────────────────────────────────────────────────────
LSADRA_RETENTION_DAYS=30

# ── Metrics ──────────────────────────────────────────────────────────────
LSADRA_METRICS_INTERVAL_MINUTES=5

DISCORD_WEBHOOK_URL=  # your Discord webhook URL — put the real value in .env (gitignored), never here
